{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dorohedoro/contracts/security-posture-rules-loaded-v1.schema.json",
  "title": "SecurityPostureRulesLoadedV1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "event_name",
    "event_id",
    "created_at",
    "agent_id",
    "hostname",
    "source_path",
    "rules_digest",
    "package_rule_count",
    "watchlist"
  ],
  "properties": {
    "schema_version": { "const": "v1" },
    "event_name": { "const": "security.posture.rules.loaded.v1" },
    "event_id": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "format": "date-time" },
    "agent_id": { "type": "string", "minLength": 1 },
    "hostname": { "type": "string", "minLength": 1 },
    "source_path": { "type": "string", "minLength": 1 },
    "rules_digest": { "type": "string", "minLength": 1 },
    "package_rule_count": { "type": "integer", "minimum": 0 },
    "watchlist": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    }
  }
}
