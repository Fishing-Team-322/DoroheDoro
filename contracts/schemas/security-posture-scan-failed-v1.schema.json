{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dorohedoro/contracts/security-posture-scan-failed-v1.schema.json",
  "title": "SecurityPostureScanFailedV1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "event_name",
    "event_id",
    "created_at",
    "agent_id",
    "hostname",
    "profile",
    "started_at",
    "error_kind",
    "error_code",
    "error_message"
  ],
  "properties": {
    "schema_version": { "const": "v1" },
    "event_name": { "const": "security.posture.scan.failed.v1" },
    "event_id": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "format": "date-time" },
    "agent_id": { "type": "string", "minLength": 1 },
    "hostname": { "type": "string", "minLength": 1 },
    "profile": { "enum": ["light", "balanced", "deep"] },
    "started_at": { "type": "string", "format": "date-time" },
    "finished_at": { "type": ["string", "null"], "format": "date-time" },
    "error_kind": { "type": "string", "minLength": 1 },
    "error_code": { "type": "string", "minLength": 1 },
    "error_message": { "type": "string", "minLength": 1 },
    "retry_backoff_sec": { "type": ["integer", "null"], "minimum": 0 }
  }
}
