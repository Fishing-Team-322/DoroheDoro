RUST_LOG=info

POSTGRES_DSN=postgres://postgres:postgres@localhost:5432/doro
NATS_URL=nats://localhost:4222

ENROLLMENT_HTTP_ADDR=0.0.0.0:8081
CONTROL_HTTP_ADDR=0.0.0.0:8082
DEPLOYMENT_HTTP_ADDR=0.0.0.0:8083
INGESTION_HTTP_ADDR=0.0.0.0:8084
QUERY_ALERT_HTTP_ADDR=0.0.0.0:8085

ENROLLMENT_DEV_BOOTSTRAP_TOKEN=dev-bootstrap-token

DEPLOYMENT_EXECUTOR_KIND=ansible
EDGE_PUBLIC_URL=http://localhost:8080
EDGE_GRPC_ADDR=localhost:9090
AGENT_STATE_DIR_DEFAULT=/var/lib/doro-agent
OPENSEARCH_URL=http://localhost:9200
OPENSEARCH_INDEX_PREFIX=doro
OPENSEARCH_USERNAME=
OPENSEARCH_PASSWORD=
CLICKHOUSE_DSN=http://default:clickhouse@localhost:8123
CLICKHOUSE_DATABASE=doro
CLICKHOUSE_TABLE=logs
RARE_FINGERPRINT_ENABLED=true
RARE_FINGERPRINT_WINDOW_MINUTES=60
RARE_FINGERPRINT_MAX_COUNT=1
RARE_FINGERPRINT_SEVERITY=medium
ANOMALY_EVALUATION_INTERVAL_SECS=60
ANOMALY_RULE_CACHE_TTL_SECS=30

# Required ansible executor settings
ANSIBLE_RUNNER_BIN=/usr/local/bin/ansible-runner
ANSIBLE_PLAYBOOK_PATH=../deployments/ansible/playbooks/install-agent.yml
DEPLOYMENT_TEMP_DIR=/tmp/doro-deployment-plane
AGENT_ARTIFACT_MANIFEST_URL=http://localhost:18081/manifest.json
AGENT_RELEASE_BASE_URL=http://localhost:18081
AGENT_ARTIFACT_VERSION=0.2.0
AGENT_PREFERRED_PACKAGE_TYPE=deb
VAULT_ADDR=http://localhost:8200
VAULT_ROLE_ID=dev-role-id
VAULT_SECRET_ID=dev-secret-id
AGENT_MTLS_CA_VAULT_REF=secret/data/agent/ca
AGENT_MTLS_CERT_VAULT_REF=secret/data/agent/cert
AGENT_MTLS_KEY_VAULT_REF=secret/data/agent/key

# Optional mock executor settings for isolated tests
MOCK_EXECUTOR_STEP_DELAY_MS=5
MOCK_EXECUTOR_FAIL_MODE=never
MOCK_EXECUTOR_FAIL_HOSTS=
