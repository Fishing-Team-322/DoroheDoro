PUBLIC_BASE_URL=https://edge.example.com
EDGE_PUBLIC_URL=https://edge.example.com
AGENT_PUBLIC_GRPC_ADDR=edge.example.com:443
NGINX_SERVER_NAME=edge.example.com

# Point to a directory that contains:
# - server.crt
# - server.key
# - ca.crt
# - agent.crt (optional, for vault-init client cert seeding)
# - agent.key (optional, for vault-init client key seeding)
SERVER_CERTS_DIR=./deployments/examples/server-certs

# Override if you keep the edge-api server env file elsewhere.
EDGE_API_SERVER_ENV_FILE=./edge_api/.env.server
