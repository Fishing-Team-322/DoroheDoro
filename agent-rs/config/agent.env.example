EDGE_URL=https://edge.example.local
EDGE_GRPC_ADDR=edge.example.local:7443
BOOTSTRAP_TOKEN=replace-with-bootstrap-token
STATE_DIR=/var/lib/doro-agent
LOG_LEVEL=info
TRANSPORT_MODE=edge
INSTALL_MODE=tarball
HEARTBEAT_INTERVAL_SEC=30
DIAGNOSTICS_INTERVAL_SEC=30
POLICY_REFRESH_INTERVAL_SEC=30
SPOOL_ENABLED=true
SPOOL_DIR=/var/lib/doro-agent/spool
SPOOL_MAX_DISK_BYTES=268435456
SECURITY_SCAN_ENABLED=true
SECURITY_SCAN_INTERVAL_SEC=3600
SECURITY_SCAN_VERSION_RULES_PATH=/etc/doro-agent/security-rules.yaml
