# Optional environment overrides for packaged/container runs.
# Leave values commented on fresh installs so `/etc/doro-agent/config.yaml`
# remains the source of truth until an operator intentionally overrides it.
#
# EDGE_URL=https://edge.example.local
# EDGE_GRPC_ADDR=edge.example.local:7443
# BOOTSTRAP_TOKEN=replace-with-bootstrap-token
# STATE_DIR=/var/lib/doro-agent
# LOG_LEVEL=info
# HEARTBEAT_INTERVAL_SEC=30
# DIAGNOSTICS_INTERVAL_SEC=30
# POLICY_REFRESH_INTERVAL_SEC=30
# BATCH_MAX_EVENTS=500
# BATCH_MAX_BYTES=524288
# BATCH_FLUSH_INTERVAL_MS=2000
# BATCH_COMPRESS_THRESHOLD_BYTES=16384
# QUEUE_EVENT_CAPACITY=4096
# QUEUE_SEND_CAPACITY=32
# QUEUE_EVENT_BYTES_SOFT_LIMIT=8388608
# QUEUE_SEND_BYTES_SOFT_LIMIT=16777216
# DEGRADED_FAILURE_THRESHOLD=3
# DEGRADED_SERVER_UNAVAILABLE_SEC=30
# DEGRADED_QUEUE_PRESSURE_PCT=80
# DEGRADED_QUEUE_RECOVER_PCT=40
# DEGRADED_UNACKED_LAG_BYTES=16777216
# DEGRADED_SHUTDOWN_SPOOL_GRACE_SEC=5
# SPOOL_ENABLED=true
# SPOOL_DIR=/var/lib/doro-agent/spool
# SPOOL_MAX_DISK_BYTES=268435456
# TRANSPORT_MODE=edge
# INSTALL_MODE=auto
# ALLOW_MACHINE_ID=false
# TLS_CA_PATH=/etc/doro-agent/pki/ca.pem
# TLS_CERT_PATH=/etc/doro-agent/pki/agent.pem
# TLS_KEY_PATH=/etc/doro-agent/pki/agent.key
# TLS_SERVER_NAME=logs.example.com
# CLUSTER_ID=cluster-a
# CLUSTER_NAME=production
# SERVICE_NAME=system-logs
# ENVIRONMENT=prod
