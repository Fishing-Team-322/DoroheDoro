{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dorohedoro.local/schemas/agent-release-manifest.json",
  "title": "Doro Agent Release Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "version", "generated_at", "artifacts"],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "platform",
          "arch",
          "package_type",
          "distro_family",
          "install_mode",
          "artifact_name",
          "artifact_path",
          "checksum_file",
          "sha256"
        ],
        "properties": {
          "platform": {
            "type": "string",
            "enum": ["linux"]
          },
          "arch": {
            "type": "string",
            "enum": ["amd64", "arm64"]
          },
          "package_type": {
            "type": "string",
            "enum": ["tar.gz", "deb"]
          },
          "distro_family": {
            "type": "string",
            "enum": ["generic-glibc", "debian", "astra-linux"]
          },
          "install_mode": {
            "type": "string",
            "enum": ["tarball", "package"]
          },
          "artifact_name": {
            "type": "string",
            "minLength": 1
          },
          "artifact_path": {
            "type": "string",
            "minLength": 1
          },
          "checksum_file": {
            "type": "string",
            "minLength": 1
          },
          "bundle_root": {
            "type": "string"
          },
          "sha256": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          },
          "packaging_preference": {
            "type": "integer",
            "minimum": 1
          }
        }
      }
    }
  }
}
